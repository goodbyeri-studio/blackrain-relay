{
	admin off
}

relay.goodbyeri.cc {
	encode zstd gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	log {
		output file /var/log/caddy/blackrain-relay-access.log {
			roll_size 100MiB
			roll_keep 5
			roll_keep_for 168h
		}
		format json
	}

	reverse_proxy 127.0.0.1:3000 {
		flush_interval -1
		transport http {
			dial_timeout 5s
		}
	}
}
